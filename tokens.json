{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Emotional music personalization studio — warm cream & deep teal palette with gold accents. Serif + sans-serif pairing for editorial warmth and functional clarity. Designed for a 50+ audience: high contrast, large type, zero dark mode, no generic social proof in hero.\n",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.173,
          0.365,
          0.388
        ],
        "hex": "#2c5d63"
      }
    },
    "cream": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.957,
          0.933,
          0.863
        ],
        "hex": "#f4eedc"
      }
    },
    "cream-alt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.953,
          0.925
        ],
        "hex": "#f5f3ec"
      }
    },
    "teal": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.173,
          0.365,
          0.388
        ],
        "hex": "#2c5d63"
      }
    },
    "teal-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.102,
          0.239,
          0.259
        ],
        "hex": "#1a3d42"
      }
    },
    "gold": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.918,
          0.631,
          0.082
        ],
        "hex": "#eaa115"
      }
    },
    "gold-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.851,
          0.565,
          0.043
        ],
        "hex": "#d9900b"
      }
    },
    "white": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "whatsapp": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.145,
          0.827,
          0.4
        ],
        "hex": "#25d366"
      }
    },
    "stripe-green": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          0.659,
          0.329
        ],
        "hex": "#33a854"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    },
    "4xl": {
      "$value": {
        "value": 80,
        "unit": "px"
      }
    },
    "5xl": {
      "$value": {
        "value": 120,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 10,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 28,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "heading-serif": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Merriweather",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "heading-sans": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": 0.05,
          "unit": "em"
        }
      }
    },
    "body-serif": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Merriweather",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sans": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.25,
          "unit": "em"
        }
      }
    },
    "display-script": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Great Vibes"
      }
    },
    "display-hand": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Caveat",
        "fontWeight": 500
      }
    },
    "obra-heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 30,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    }
  }
}
