{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && tsc --noEmit && esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external",
