{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Warm editorial minimalism for personalized music. Cream canvas, teal ink, gold accent — where love stories become songs.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.173,
          0.365,
          0.388
        ],
        "hex": "#2c5d63"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.239,
          0.478,
          0.506
        ],
        "hex": "#3d7a81"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.918,
          0.631,
          0.082
        ],
        "hex": "#eaa115"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.957,
          0.933,
          0.863
        ],
        "hex": "#f4eedc"
      }
    },
    "whatsapp": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.145,
          0.827,
          0.4
        ],
        "hex": "#25d366"
      }
    },
    "dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.071,
          0.071,
          0.071
        ],
        "hex": "#121212"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.173,
          0.365,
          0.388
        ],
        "hex": "#2c5d63"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 80,
        "unit": "px"
      }
    },
    "hero": {
      "$value": {
        "value": 128,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        },
        "lineHeight": 1.1
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 2.25,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        },
        "lineHeight": 1.2
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        },
        "lineHeight": 1.2
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Merriweather",
        "fontSize": {
          "value": 1.125,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.625
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Merriweather",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    },
    "price": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Open Sans",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 800,
        "lineHeight": 1
      }
    }
  }
}
